int main() {
    // 创造 35 个局部变量
    int v1 = 1;
    int v2 = 2;
    int v3 = 3;
    int v4 = 4;
    int v5 = 5;
    int v6 = 6;
    int v7 = 7;
    int v8 = 8;
    int v9 = 9;
    int v10 = 10;
    int v11=11;
    int v12=12;
    int v13=13;
    int v14=14;
    int v15=15;
    int v16=16;
    int v17=17;
    int v18=18;
    int v19=19;
    int v20=20;
    int v21=21;
    int v22=22;
    int v23=23;
    int v24=24;
    int v25=25;
    int v26=26;
    int v27=27;
    int v28=28;
    int v29=29;
    int v30=30;
    int v31=31;
    int v32=32;
    int v33=33;
    int v34=34;
    int v35=35;

    // 为了让这 35 个变量同时处于“活跃（Alive）”状态，
    // 我们必须在前面修改它们，在最后使用它们。
    v1 = v1 * 2; v2 = v2 * 2; v3 = v3 * 2; v4 = v4 * 2; v5 = v5 * 2;
    v6 = v6 * 2; v7 = v7 * 2; v8 = v8 * 2; v9 = v9 * 2; v10 = v10 * 2;
    v11 = v11 * 2; v12 = v12 * 2; v13 = v13 * 2; v14 = v14 * 2; v15 = v15 * 2;
    v16 = v16 * 2; v17 = v17 * 2; v18 = v18 * 2; v19 = v19 * 2; v20 = v20 * 2;
    v21 = v21 * 2; v22 = v22 * 2; v23 = v23 * 2; v24 = v24 * 2; v25 = v25 * 2;
    v26 = v26 * 2; v27 = v27 * 2; v28 = v28 * 2; v29 = v29 * 2; v30 = v30 * 2;
    v31 = v31 * 2; v32 = v32 * 2; v33 = v33 * 2; v34 = v34 * 2; v35 = v35 * 2;

    // 超级连加，迫使寄存器分配器崩溃并疯狂倒腾栈内存
    return v1 + v2 + v3 + v4 + v5 + v6 + v7 + v8 + v9 + v10 +
           v11 + v12 + v13 + v14 + v15 + v16 + v17 + v18 + v19 + v20 +
           v21 + v22 + v23 + v24 + v25 + v26 + v27 + v28 + v29 + v30 +
           v31 + v32 + v33 + v34 + v35;
}