// 4 个全局变量
int g1 = 10;
int g2 = 20;
int g3 = 30;
int g4 = 40;

int main() {
    // 4 个局部变量
    int l1 = 1;
    int l2 = 2;
    int l3 = 3;
    int l4 = 4;

    // 疯狂交叉修改
    g1 = g1 + l1;      // 用到 g1, l1
    g2 = g2 + l2;      // 用到 g2, l2
    
    l3 = g1 + g2;      // 再次用到 g1, g2 (完美编译器这里不会重新 lw)
    g3 = g3 + l3;      // 用到 g3, l3
    
    l4 = g3 + g4;      // 再次用到 g3, 用到 g4
    g4 = g4 + l4;      // 再次用到 g4
    
    g1 = g1 + g4;      // 再次用到 g1, g4

    return g1 + g2 + g3 + g4 + l1 + l2 + l3 + l4;
}