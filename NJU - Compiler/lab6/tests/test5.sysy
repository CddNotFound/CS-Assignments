int get_abs(int value) {
    if (value < 0) {
        return 0 - value;
    }
    return value;
}

int check_range(int val, int min, int max) {
    if (val >= min && val <= max) {
        return 1;
    }
    return 0;
}

int main_test(int a, int b) {
    int abs_a = get_abs(a);
    int abs_b = get_abs(b);
    int total = 0;
    
    while (abs_a > 0) {
        if (check_range(abs_a, 5, 10) == 1) {
            total = total + abs_b;
        }
        abs_a = abs_a - 1;
    }
    
    return total;
}