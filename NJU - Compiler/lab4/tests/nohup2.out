; ModuleID = 'module'
source_filename = "module"

@a = global i32 1
@b = global i32 3
@c = global i32 4

define i32 @main() {
mainEntry:
  %d = alloca i32, align 4
  %a = load i32, i32* @a, align 4
  %b = load i32, i32* @b, align 4
  %result = add i32 %a, %b
  store i32 %result, i32* %d, align 4
  %f = alloca i32, align 4
  %d1 = load i32, i32* %d, align 4
  %b2 = load i32, i32* @b, align 4
  %result3 = mul i32 %d1, %b2
  %c = load i32, i32* @c, align 4
  %result4 = srem i32 %result3, %c
  store i32 %result4, i32* %f, align 4
  %a5 = load i32, i32* @a, align 4
  %b6 = load i32, i32* @b, align 4
  %result7 = add i32 %a5, %b6
  store i32 %result7, i32* @a, align 4
  %f8 = load i32, i32* %f, align 4
  %a9 = load i32, i32* @a, align 4
  %b10 = load i32, i32* @b, align 4
  %result11 = add i32 %a9, %b10
  %c12 = load i32, i32* @c, align 4
  %result13 = add i32 %result11, %c12
  %d14 = load i32, i32* %d, align 4
  %result15 = srem i32 %result13, %d14
  %result16 = sub i32 %f8, %result15
  ret i32 %result16
}
