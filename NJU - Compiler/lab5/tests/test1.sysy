int test_relational(int a, int b) {
    int result = 0;
    if (a == b) {
        result = 1;
    } else {
        if (a != b) {
            if (a > b) {
                result = 2;
            }
            if (a >= b) {
                result = result + 10;
            }
            if (a < b) {
                result = 3;
            }
            if (a <= b) {
                result = result + 20;
            }
        }
    }
    return result;
}