; ModuleID = 'module'
source_filename = "module"

define i32 @test_while_loop(i32 %0) {
test_while_loopEntry:
  %n = alloca i32, align 4
  store i32 %0, i32* %n, align 4
  %sum = alloca i32, align 4
  store i32 0, i32* %sum, align 4
  %i = alloca i32, align 4
  store i32 0, i32* %i, align 4
  br label %WhileCondition1

WhileCondition1:                                  ; preds = %WhileLoop2, %test_while_loopEntry
  %i1 = load i32, i32* %i, align 4
  %n2 = load i32, i32* %n, align 4
  %result = icmp sle i32 %i1, %n2
  %result3 = zext i1 %result to i32
  %cond1 = icmp ne i32 %result3, 0
  br i1 %cond1, label %WhileLoop2, label %WhileExit3

WhileLoop2:                                       ; preds = %WhileCondition1
  %sum4 = load i32, i32* %sum, align 4
  %i5 = load i32, i32* %i, align 4
  %result6 = add i32 %sum4, %i5
  store i32 %result6, i32* %sum, align 4
  %i7 = load i32, i32* %i, align 4
  %result8 = add i32 %i7, 1
  store i32 %result8, i32* %i, align 4
  br label %WhileCondition1

WhileExit3:                                       ; preds = %WhileCondition1
  %sum9 = load i32, i32* %sum, align 4
  ret i32 %sum9
}
