; ModuleID = 'module'
source_filename = "module"

define i32 @main() {
mainEntry:
  %a = alloca i32, align 4
  store i32 0, i32* %a, align 4
  %count = alloca i32, align 4
  store i32 0, i32* %count, align 4
  br label %WhileCondition1

WhileCondition1:                                  ; preds = %IfExit5, %mainEntry
  %a1 = load i32, i32* %a, align 4
  %result = icmp sle i32 %a1, 0
  %result2 = zext i1 %result to i32
  %cond1 = icmp ne i32 %result2, 0
  br i1 %cond1, label %WhileLoop2, label %WhileExit3

WhileLoop2:                                       ; preds = %WhileCondition1
  %a3 = load i32, i32* %a, align 4
  %result4 = sub i32 %a3, 1
  store i32 %result4, i32* %a, align 4
  %count5 = load i32, i32* %count, align 4
  %result6 = add i32 %count5, 1
  store i32 %result6, i32* %count, align 4
  %a7 = load i32, i32* %a, align 4
  %result8 = icmp slt i32 %a7, -20
  %result9 = zext i1 %result8 to i32
  %cond2 = icmp ne i32 %result9, 0
  br i1 %cond2, label %IfTrue4, label %IfExit5

WhileExit3:                                       ; preds = %IfTrue4, %WhileCondition1
  %count10 = load i32, i32* %count, align 4
  ret i32 %count10

IfTrue4:                                          ; preds = %WhileLoop2
  br label %WhileExit3

IfExit5:                                          ; preds = %WhileLoop2
  br label %WhileCondition1
}
